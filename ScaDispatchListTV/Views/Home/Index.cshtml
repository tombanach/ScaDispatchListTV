@model IEnumerable<Order>
@using System.Globalization

@{
    ViewData["Title"] = "ScaDispatchListTV";
    var rows = Model == null ? new List<Order>() : Model.ToList();
    var renderTime = DateTime.Now;
    var displayDate = DateTime.Today.ToString("dd.MM.yyyy", CultureInfo.CurrentCulture);
    string[] tableHeaders = new string[]
    {
        "Klient",
        "Zamówienie",
        "Nazwa",
        "Il.zam",
        "Gotowość",
        "Data wys."
    };
}

@functions {
    private static decimal ParseDecimal(string value)
    {
        if (decimal.TryParse(value, NumberStyles.Any, CultureInfo.CurrentCulture, out var currentValue))
        {
            return currentValue;
        }

        if (decimal.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var invariantValue))
        {
            return invariantValue;
        }

        return 0;
    }

    private static string FormatQuantity(string value)
    {
        if (decimal.TryParse(value, NumberStyles.Any, CultureInfo.CurrentCulture, out var currentValue))
        {
            return currentValue.ToString("0.##", CultureInfo.CurrentCulture);
        }

        if (decimal.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var invariantValue))
        {
            return invariantValue.ToString("0.##", CultureInfo.CurrentCulture);
        }

        return value;
    }

    private static string FormatPercent(decimal value)
    {
        return value.ToString("0.##", CultureInfo.CurrentCulture) + "%";
    }

    private static string FormatDate(string value)
    {
        if (DateTime.TryParse(value, CultureInfo.CurrentCulture, DateTimeStyles.None, out var currentDate))
        {
            return currentDate.ToString("dd.MM.yyyy", CultureInfo.CurrentCulture);
        }

        if (DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var invariantDate))
        {
            return invariantDate.ToString("dd.MM.yyyy", CultureInfo.CurrentCulture);
        }

        return value;
    }

    private static string GetGotClass(decimal got)
    {
        if (got >= 100)
        {
            return "got-complete";
        }

        if (got > 0)
        {
            return "got-progress";
        }

        return "got-empty";
    }

    private static string GetRowClass(decimal got)
    {
        if (got >= 100)
        {
            return "row-complete";
        }

        if (got > 0)
        {
            return "row-progress";
        }

        return "row-empty";
    }
}

<section class="tv-page">
    <div class="tv-header">
        <div class="top-status">
            <div class="status-title">ScaDispatchList</div>
            <div class="status-meta">
                <span>Data: @displayDate</span>
                <span>Odśw.: @renderTime.ToString("HH:mm:ss", CultureInfo.CurrentCulture)</span>
                <span>Poz.: @rows.Count</span>
            </div>
        </div>
        <div class="scroll-progress" aria-hidden="true">
            <div class="scroll-progress-bar"></div>
        </div>
    </div>

    @if (rows.Count == 0)
    {
        <div class="empty-state">Brak pozycji do wyświetlenia</div>
    }
    else
    {
        <div class="table-frame">
            <table class="dispatch-table">
                <colgroup>
                    <col class="col-client" />
                    <col class="col-order" />
                    <col class="col-name" />
                    <col class="col-qty" />
                    <col class="col-ready" />
                    <col class="col-date" />
                </colgroup>
                <thead>
                    <tr>
                        @foreach (var head in tableHeaders)
                        {
                            <th>@head</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in rows)
                    {
                        var got = ParseDecimal(order.Got);
                        <tr class="@GetRowClass(got)">
                            <td>@order.Klient</td>
                            <td>@order.Zamowienie</td>
                            <td>@order.Nazwa</td>
                            <td class="numeric">@FormatQuantity(order.IlZam)</td>
                            <td class="got-cell">
                                <span class="got-badge @GetGotClass(got)">@FormatPercent(got)</span>
                            </td>
                            <td>@FormatDate(order.DataWys)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
